<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messenger</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/html/css/style.css">
</head>
<body>
    <div class="container-fluid h-100">
        <div class="row h-100">
            <div class="col-md-3 bg-light border-end p-0">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Konverzace</h5>
                    <a href="/odhlaseni" class="btn btn-sm btn-outline-danger">Odhlásit</a>
                </div>

                <?php if (!empty($flashMessages ?? [])) : ?>
                    <div class="p-2">
                        <?php foreach ($flashMessages as $type => $messages) : ?>
                            <?php
                            $classname = match ($type) {
                                'error' => 'alert-danger',
                                'success' => 'alert-success',
                                'warning' => 'alert-warning',
                                default => 'alert-info',
                            };
                            ?>
                            <?php foreach ($messages as $message) : ?>
                                <div class="alert <?= $classname ?> py-2 mb-2 small">
                                    <?= htmlspecialchars((string)$message, ENT_QUOTES, 'UTF-8') ?>
                                </div>
                            <?php endforeach; ?>
                        <?php endforeach; ?>
                    </div>
                <?php endif; ?>

                <div class="overflow-auto" style="height: calc(100vh - 130px);">
                    <?php if (empty($conversations)) : ?>
                        <div class="p-3 text-muted">Zatím nemáte žádnou konverzaci.</div>
                    <?php else : ?>
                        <?php foreach ($conversations as $conversation) : ?>
                            <?php $conversationUuid = $conversation->getUuid()->toString(); ?>
                            <a
                                href="/messenger/<?= urlencode($conversationUuid) ?>"
                                class="contact-item d-block text-decoration-none <?= $selectedConversationId === $conversationUuid ? 'active' : '' ?>"
                            >
                                <strong><?= htmlspecialchars($conversation->getName() ?: 'Konverzace', ENT_QUOTES, 'UTF-8') ?></strong>
                            </a>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>
            </div>

            <div class="col-md-6 d-flex flex-column p-0">
                <div class="p-3 border-bottom bg-white">
                    <h5 class="mb-0">
                        <?= $selectedConversationId !== '' ? 'Chat' : 'Vyberte konverzaci' ?>
                    </h5>
                </div>

                <div class="flex-grow-1 p-3 overflow-auto" style="background: #f8f9fa;">
                    <?php if ($selectedConversationId === '') : ?>
                        <p class="text-muted">Vyberte konverzaci vlevo nebo založte novou vpravo.</p>
                    <?php elseif (empty($messages)) : ?>
                        <p class="text-muted">V této konverzaci zatím nejsou žádné zprávy.</p>
                    <?php else : ?>
                        <?php foreach ($messages as $message) : ?>
                            <?php $isMine = $currentUser && ($message->getUser()->getUuid()->toString() === $currentUser->getUuid()->toString()); ?>
                            <div class="message <?= $isMine ? 'sent' : 'received' ?>">
                                <div class="small fw-semibold mb-1">
                                    <?= htmlspecialchars($message->getUser()->getUsername(), ENT_QUOTES, 'UTF-8') ?>
                                </div>
                                <div><?= nl2br(htmlspecialchars($message->getMessage(), ENT_QUOTES, 'UTF-8')) ?></div>
                                <div class="message-time">
                                    <?= $message->getCreatedAt()->format('d.m.Y H:i') ?>
                                </div>
                            </div>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>

                <?php if ($selectedConversationId !== '') : ?>
                    <div class="p-3 border-top bg-white">
                        <!-- TODO(nice-to-have): AJAX odeslání a nekonečný scroll viz README.md -->
                        <form method="post" action="/messenger/<?= urlencode($selectedConversationId) ?>" class="d-flex gap-2">
                            <input type="text" name="message" class="form-control" placeholder="Napište zprávu..." required maxlength="2000">
                            <button type="submit" class="btn btn-primary">Odeslat</button>
                        </form>
                    </div>
                <?php endif; ?>
            </div>

            <div class="col-md-3 bg-light border-start p-0">
                <div class="p-3 border-bottom">
                    <h5 class="mb-0">Uživatelé</h5>
                </div>
                <div class="overflow-auto" style="height: calc(100vh - 70px);">
                    <?php if (empty($contacts)) : ?>
                        <div class="p-3 text-muted">Žádní další uživatelé.</div>
                    <?php else : ?>
                        <?php foreach ($contacts as $contact) : ?>
                            <a href="/messenger/nova/<?= urlencode($contact->getUuid()->toString()) ?>" class="contact-item d-block text-decoration-none text-dark">
                                <strong><?= htmlspecialchars($contact->getUsername(), ENT_QUOTES, 'UTF-8') ?></strong>
                            </a>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
