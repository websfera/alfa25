<body class="bg-light">
<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center mb-4">Messenger</h3>
                    <?php foreach ($flashMessages as $type => $messages) : ?>
                        <?php
                        switch($type) {
                            case 'error': $classname = 'alert-danger';
                                break;
                            case 'success': $classname = 'alert-success';
                                break;
                            case 'warning': $classname = 'alert-warning';
                                break;
                            default:
                                $classname = 'alert-info';
                        }
                        ?>
                        <?php foreach ($messages as $message) : ?>
                            <div class="alert <?= $classname ?>">
                                <?= $message ?>
                            </div>
                        <?php endforeach; ?>
                    <?php endforeach; ?>
                    <form id="loginForm" method="post">
                        <div class="mb-3">
                            <label for="username" class="form-label">Uživatelské jméno</label>
                            <input type="text" name="username" class="form-control" id="username" required>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Heslo</label>
                            <input type="password" name="password" class="form-control" id="password" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Přihlásit se</button>
                    </form>
                    <div class="text-center mt-3">
                        <a href="register.php">Registrovat se</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
